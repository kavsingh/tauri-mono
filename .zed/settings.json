{
	"format_on_save": "on",
	"hard_tabs": true,
	"preferred_line_length": 84,
	"prettier": { "allowed": false },
	"formatter": [{ "language_server": { "name": "oxfmt" } }],
	"code_actions_on_format": { "source.fixAll.oxc": true },

	"lsp": {
		"rust-analyzer": {
			"initialization_options": {
				"check": { "command": "clippy" },
				"diagnostics": { "styleLints": { "enable": true } },
				"rustfmt": { "extraArgs": ["+nightly"] }
			}
		},

		"tailwindcss-language-server": {
			"settings": {
				"validate": true,
				"classFunctions": ["tj", "tm", "tv"],
				"classAttributes": [
					"class",
					"classList",
					"className",
					".+ClassName",
					".+ClassNames"
				],
				"experimental": {
					"configFile": {
						"apps/app/src/index.css": "apps/app/src/**/*"
					}
				}
			}
		}
	},

	"languages": {
		"Rust": {
			"formatter": [{ "language_server": { "name": "rust-analyzer" } }]
		},

		"TypeScript": {
			"language_servers": [
				"tsgo",
				"oxlint",
				"tailwindcss-language-server",
				"oxfmt"
			]
		},

		"TSX": {
			"language_servers": [
				"tsgo",
				"oxlint",
				"tailwindcss-language-server",
				"oxfmt"
			]
		},

		"JavaScript": { "language_servers": ["tsgo", "oxlint", "oxfmt"] },

		"CSS": {
			"language_servers": [
				"tailwindcss-intellisense-css",
				"tailwindcss-language-server",
				"oxfmt",
				"!vscode-css-language-server"
			]
		}
	}
}
