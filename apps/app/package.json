{
	"name": "app",
	"version": "1.0.0-dev.0",
	"description": "a tauri app",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"tdd:ui": "vitest",
		"test": "bun test:tauri && bun test:ui",
		"test:ci": "bun test:ui --silent --coverage",
		"test:ui": "vitest run",
		"test:tauri": "cd src-tauri && cargo test",
		"lint": "bun lint:ui",
		"lint:ui": "cross-env tsr generate && oxlint && oxfmt --check",
		"lint:tauri": "cargo clippy --all-targets --all-features",
		"before:dev": "cross-env bun build:isolation && vite dev",
		"before:build": "cross-env bun build:isolation && rimraf ./dist && vite build",
		"dev": "tauri dev",
		"build:mac": "tauri build --target universal-apple-darwin",
		"build:win": "tauri build --target x86_64-pc-windows-msvc",
		"build:isolation": "cross-env rimraf ./dist-isolation && vite -c vite.isolation.config.ts build",
		"testscript": "bun scripts/testscript.ts"
	},
	"dependencies": {
		"@tanstack/solid-devtools": "0.8.2",
		"@tanstack/solid-query": "5.99.0",
		"@tanstack/solid-query-devtools": "5.99.0",
		"@tanstack/solid-router": "1.168.20",
		"@tanstack/solid-router-devtools": "1.166.13",
		"@tauri-apps/api": "2.10.1",
		"@tauri-apps/plugin-dialog": "2.7.0",
		"@tauri-apps/plugin-log": "2.8.0",
		"@tauri-apps/plugin-store": "2.4.2",
		"solid-js": "1.9.12",
		"tailwind-merge": "3.5.0",
		"tailwind-variants": "3.2.2"
	},
	"devDependencies": {
		"@solidjs/testing-library": "0.8.10",
		"@tailwindcss/vite": "4.2.2",
		"@tanstack/devtools-vite": "0.6.0",
		"@tanstack/eslint-plugin-router": "1.161.6",
		"@tanstack/router-cli": "1.166.33",
		"@tanstack/router-plugin": "1.167.22",
		"@tauri-apps/cli": "2.10.1",
		"@testing-library/dom": "10.4.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/user-event": "14.6.1",
		"@tsconfig/vite-react": "7.0.2",
		"@vitest/coverage-v8": "4.1.4",
		"caniuse-lite": "1.0.30001788",
		"eslint-plugin-better-tailwindcss": "4.4.1",
		"eslint-plugin-jest-dom": "5.5.0",
		"eslint-plugin-solid": "0.14.5",
		"eslint-plugin-testing-library": "7.16.2",
		"jsdom": "29.0.2",
		"tailwindcss": "4.2.2",
		"terser": "5.46.1",
		"tw-animate-css": "1.4.0",
		"vite": "8.0.8",
		"vite-plugin-checker": "0.13.0",
		"vite-plugin-solid": "2.11.12",
		"vite-tsconfig-paths": "6.1.1",
		"vitest": "4.1.4",
		"vitest-canvas-mock": "1.1.4"
	}
}
