{
	"name": "tauri-mono",
	"version": "0.0.0",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git@host.com:your/repo"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "nx dev app --outputStyle stream",
		"test": "nx run-many -t test --outputStyle stream",
		"test:ci": "nx run-many -t test:ci --outputStyle stream",
		"lint": "nx run-many -t lint --outputStyle stream && tombi lint --error-on-warnings",
		"build:mac": "nx build:mac app",
		"build:win": "nx build:win app",
		"clean:nx": "rimraf ./**/.nx --glob",
		"clean:modules": "rimraf ./**/node_modules --glob",
		"clean:targets": "rimraf ./**/target --glob"
	},
	"devDependencies": {
		"@tsconfig/bun": "1.0.10",
		"@tsconfig/strictest": "2.0.8",
		"@types/bun": "1.3.12",
		"@typescript/native-preview": "7.0.0-dev.20260418.1",
		"cross-env": "10.1.0",
		"lefthook": "2.1.6",
		"nx": "22.6.5",
		"oxfmt": "0.45.0",
		"oxlint": "1.60.0",
		"oxlint-tsgolint": "0.21.1",
		"rimraf": "6.1.3",
		"tombi": "0.9.18"
	},
	"packageManager": "bun@1.3.12",
	"trustedDependencies": [
		"lefthook",
		"nx",
		"tombi"
	]
}
