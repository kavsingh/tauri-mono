{
	"$schema": "../../node_modules/oxlint/configuration_schema.json",
	"extends": ["../../.oxlintrc.json"],
	"env": { "node": true, "browser": false },
	"ignorePatterns": [
		"dist/**",
		"dist-isolation/**",
		"reports/**",
		"**/__generated__/**",
		"!**/__generated__/__mocks__/**"
	],
	"overrides": [
		{
			"files": ["src/**", "src-isolation/**"],
			"env": { "browser": true, "node": false }
		}
	]
}
